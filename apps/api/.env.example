USE_MEMORY_STORE=true
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=swarmdesk

# auto | xai | google | openai | anthropic
LLM_PROVIDER=auto

# xAI (Grok) — OpenAI-compatible
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# Google Gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI / compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-5

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
